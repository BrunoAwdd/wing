# Configuração de DESENVOLVIMENTO local. Para produção use
# .env.production.example como base.
#
# BACKEND_URL fica vazio em dev de propósito: o proxy do webpack devServer
# (webpack.config.js) encaminha "/api/*" pro backend local, então chamadas
# relativas já funcionam sem precisar apontar pra um host explícito.
BACKEND_URL=""
WING_FEATURE_DOCUMENT_DESIGN=false
WING_FEATURE_LEGAL_ANALYSIS=false
WING_FEATURE_MICROSOFT_SSO=false
