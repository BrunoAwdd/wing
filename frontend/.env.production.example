# M5 — modelo de configuração de PRODUÇÃO. Copie pra `.env` no ambiente de
# build de produção.
#
# BACKEND_URL aqui É o domínio público do backend (ex.:
# https://api.wing.com.br, sem barra final) — em produção não existe proxy
# de devServer, então o front precisa saber pra onde apontar de verdade.
# Esse valor fica embutido no bundle JS publicado (via dotenv-webpack),
# então não é segredo, mas também não deve trocar sem rebuild.
BACKEND_URL="https://api.wing.com.br"
WING_FEATURE_DOCUMENT_DESIGN=false
WING_FEATURE_LEGAL_ANALYSIS=false
WING_FEATURE_MICROSOFT_SSO=false

# PROD_APP_DOMAIN NÃO vai neste arquivo — é lido diretamente por
# webpack.config.js (process.env do processo do Node que roda o build, não
# pelo bundle), então precisa ser uma variável de ambiente do
# shell/pipeline de CI no momento do `npm run build`, ex.:
#   PROD_APP_DOMAIN=https://app.wing.com.br npm run build
# Sem ela, o build de produção falha imediatamente (ver webpack.config.js).
