# M5 — modelo de configuração de STAGING. Mesma estrutura do
# `.env.production.example`; a aplicação não tem um modo "staging" próprio
# no código (só `NODE_ENV=production` liga as validações estritas), então
# staging roda com NODE_ENV=production também — o que muda é o domínio e,
# idealmente, o uso de credenciais/sandbox separadas das de produção real.
#
# Diferenças recomendadas em relação à produção:
#   - CORS_ALLOWED_ORIGINS aponta pro domínio de staging (ex.:
#     https://staging.app.wing.com.br), nunca o de produção nem localhost.
#   - STRIPE_* em modo teste/sandbox, não live.
#   - SUPABASE_* de um projeto separado do de produção (dados de teste não
#     devem se misturar com contas/carteiras reais).
#   - JWT_SECRET diferente do de produção (uma sessão de staging nunca deve
#     ser válida em produção nem vice-versa).

NODE_ENV=production
PORT=3005
LOG_LEVEL=DEBUG

# --- IA ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-3.5
WING_TRANSLATION_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Sessão Wing (JWT) — segredo próprio de staging, nunca o de produção ---
JWT_SECRET=
WING_SESSION_ISSUER=wing-api
WING_SESSION_AUDIENCE=wing-office-addin
WING_SESSION_TTL_SECONDS=3600
WING_REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Banco de dados (Supabase — projeto separado do de produção) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SCHEMA=wing
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- SSO Microsoft (incubado) ---
MICROSOFT_TOKEN_AUDIENCE=
MICROSOFT_REQUIRED_SCOPE=access_as_user
MICROSOFT_ALLOWED_TENANTS=
MICROSOFT_ALLOWED_CLIENT_IDS=

# --- CORS — domínio(s) de staging, sem barra final. Inclui o site
# comercial de staging (M5.1) além do add-in, já que o cadastro chama a
# API direto do navegador. Ver detalhe em .env.production.example. ---
CORS_ALLOWED_ORIGINS=

# --- Feature flags ---
WING_FEATURE_DOCUMENT_DESIGN=false
WING_FEATURE_LEGAL_ANALYSIS=false
WING_FEATURE_MICROSOFT_SSO=false

# --- Stripe (chaves de TESTE, não live) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=

# --- Limites de uso/ação ---
WING_FREE_MONTHLY_CREDITS=1000
WING_ACTION_MAX_INPUT_CHARS=120000
WING_ACTION_MAX_OUTPUT_TOKENS=4096

# --- Chat de documento ---
WING_CHAT_MAX_DOCUMENT_CHARS=120000
WING_CHAT_MAX_MESSAGE_CHARS=4000
WING_CHAT_MAX_MESSAGES=30
WING_CHAT_SESSION_TTL_MS=1800000
WING_CHAT_MAX_OUTPUT_TOKENS=2048
WING_APP_SESSION_TTL_MS=600000
WING_APP_SESSION_MAX_DURATION_MS=3600000
