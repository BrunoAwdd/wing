# M5 — modelo de configuração de PRODUÇÃO. Copie pra `.env` no ambiente de
# produção e preencha os valores reais — nunca commit o `.env` de verdade.
#
# Diferenças-chave em relação ao `.env.example` (dev):
#   - NODE_ENV=production liga as validações estritas de boot: corsConfig.ts
#     exige CORS_ALLOWED_ORIGINS explícito e derruba o processo se a lista
#     incluir localhost/o túnel de dev; index.ts serve HTTPS de verdade
#     (cert.pem/key.pem) em vez de HTTP puro.
#   - CORS_ALLOWED_ORIGINS deve ser o(s) domínio(s) oficial(is) do add-in
#     publicado — nunca localhost, nunca o túnel supercontext-ui.*.
#   - Todas as chaves de API abaixo devem ser as reais de produção, não as
#     de teste/sandbox usadas em dev.
#   - Staging: mesma estrutura deste arquivo, mas com CORS_ALLOWED_ORIGINS
#     apontando pro domínio de staging e (idealmente) chaves de API/Stripe
#     em modo sandbox — ver .env.staging.example.

NODE_ENV=production
PORT=3005
LOG_LEVEL=INFO

# --- IA ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-3.5
WING_TRANSLATION_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Sessão Wing (JWT) ---
# Gere com: deno eval "console.log(crypto.randomUUID() + crypto.randomUUID())"
# (ou qualquer gerador de 32+ bytes aleatórios). Nunca reutilize o segredo
# de dev/staging em produção.
JWT_SECRET=
WING_SESSION_ISSUER=wing-api
WING_SESSION_AUDIENCE=wing-office-addin
WING_SESSION_TTL_SECONDS=3600
WING_REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Banco de dados (Supabase) ---
SUPABASE_URL=
SUPABASE_SCHEMA=wing
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- SSO Microsoft (incubado — deixe WING_FEATURE_MICROSOFT_SSO=false até
# reativar oficialmente; ver comentário em index.ts) ---
MICROSOFT_TOKEN_AUDIENCE=
MICROSOFT_REQUIRED_SCOPE=access_as_user
MICROSOFT_ALLOWED_TENANTS=
MICROSOFT_ALLOWED_CLIENT_IDS=

# --- CORS — domínio(s) oficiais que fazem requisição direta ao backend,
# sem barra final, separados por vírgula. Inclui o add-in publicado E o
# site comercial (M5.1, pacote site/), já que o fluxo de cadastro chama
# /api/v1/auth/magic-link/* direto do navegador. NUNCA localhost/túnel
# aqui — corsConfig.ts derruba o processo no boot se detectar isso em
# produção. Ex.: https://app.wing.com.br,https://wing.com.br
CORS_ALLOWED_ORIGINS=

# --- Feature flags ---
WING_FEATURE_DOCUMENT_DESIGN=false
WING_FEATURE_LEGAL_ANALYSIS=false
WING_FEATURE_MICROSOFT_SSO=false

# --- Stripe (chaves live, não as de teste) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Rotas do site (site/), não do add-in — ver site/src/App.tsx
# (/sucesso, /cancelado). Ex.: https://wing.com.br/sucesso
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=

# --- Limites de uso/ação ---
WING_TRIAL_CREDIT_LIMIT=500
WING_FREE_ACCESS_CAP=20
WING_TRIAL_DURATION_SECONDS=2592000
WING_BASIC_MONTHLY_CREDITS=3500
WING_PRO_MONTHLY_CREDITS=8000
WING_ACTION_MAX_INPUT_CHARS=120000
WING_ACTION_MAX_OUTPUT_TOKENS=4096

# --- Chat de documento ---
WING_CHAT_MAX_DOCUMENT_CHARS=120000
WING_CHAT_MAX_MESSAGE_CHARS=4000
WING_CHAT_MAX_MESSAGES=30
WING_CHAT_SESSION_TTL_MS=1800000
WING_CHAT_MAX_OUTPUT_TOKENS=2048
WING_APP_SESSION_TTL_MS=600000
WING_APP_SESSION_MAX_DURATION_MS=3600000
