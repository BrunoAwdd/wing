# Configuração de DESENVOLVIMENTO local. Para staging/produção use
# .env.staging.example / .env.production.example como base — não este
# arquivo (faltam validações estritas de CORS/HTTPS que só se ligam com
# NODE_ENV=production, e os valores abaixo assumem localhost).
NODE_ENV=development
PORT=3005
LOG_LEVEL=INFO

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-3.5
WING_TRANSLATION_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
JWT_SECRET=
SUPABASE_URL=
SUPABASE_SCHEMA=wing
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

MICROSOFT_TOKEN_AUDIENCE=7a24a432-030d-4b5b-aa68-7c25942557f9
MICROSOFT_REQUIRED_SCOPE=access_as_user
MICROSOFT_ALLOWED_TENANTS=
MICROSOFT_ALLOWED_CLIENT_IDS=
WING_SESSION_ISSUER=wing-api
WING_SESSION_AUDIENCE=wing-office-addin
WING_SESSION_TTL_SECONDS=3600
WING_REFRESH_TOKEN_TTL_SECONDS=2592000
CORS_ALLOWED_ORIGINS=https://localhost:5173

WING_FEATURE_DOCUMENT_DESIGN=false
WING_FEATURE_LEGAL_ANALYSIS=false
WING_FEATURE_MICROSOFT_SSO=false

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# Local: https://localhost:5174/sucesso e /cancelado (dev server do site/).
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=
WING_TRIAL_CREDIT_LIMIT=500
WING_FREE_ACCESS_CAP=20
WING_TRIAL_DURATION_SECONDS=2592000
WING_BASIC_MONTHLY_CREDITS=3500
WING_PRO_MONTHLY_CREDITS=8000
WING_ACTION_MAX_INPUT_CHARS=120000
WING_ACTION_MAX_OUTPUT_TOKENS=4096

WING_CHAT_MAX_DOCUMENT_CHARS=120000
WING_CHAT_MAX_MESSAGE_CHARS=4000
WING_CHAT_MAX_MESSAGES=30
WING_CHAT_SESSION_TTL_MS=1800000
WING_CHAT_MAX_OUTPUT_TOKENS=2048
WING_APP_SESSION_TTL_MS=600000
WING_APP_SESSION_MAX_DURATION_MS=3600000
